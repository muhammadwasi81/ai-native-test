# Database — must be Postgres. For local dev, spin up via:
#   docker compose up -d
# Or use any Postgres host (Neon free tier recommended: https://neon.tech).
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/docs?schema=public"

# NextAuth — required. Generate with `openssl rand -base64 32`
AUTH_SECRET="replace-me-with-a-long-random-string"

# Tells NextAuth to trust the Host header (needed on most hosted platforms).
AUTH_TRUST_HOST=true
